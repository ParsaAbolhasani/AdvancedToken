{
  "name": "advanced-token",
  "version": "1.0.0",
  "description": "Production-ready ERC20 token with fees, pausable, snapshots, and RBAC",
  "main": "index.js",
  "scripts": {
    "test": "npx hardhat test",
    "test:gas": "REPORT_GAS=true npx hardhat test",
