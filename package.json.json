  },
  "keywords": [
    "blockchain",
    "ethereum",
    "solidity",
    "erc20",
    "smart-contract",
    "hardhat"
  ],
  "author": "Parsa Abolhasani Rad",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@openzeppelin/contracts": "^4.9.3",
    "dotenv": "^16.0.3",
    "hardhat": "^2.17.0"
  }
}